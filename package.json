{
  "name": "gameopen",
  "version": "1.1.0",
  "private": true,
  "description": "Grudge Open / Animator — combat sandbox migrated off Replit onto Grudge Studio fleet",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm --prefix artifacts/animator run dev",
    "build": "node scripts/vercel-build.mjs",
    "start:api": "node server/standalone.mjs",
    "ingest:rapier": "node scripts/ingest-threejs-rapier.mjs",
    "assets:merge": "node scripts/merge-gameopen-assets.mjs",
    "assets:manifest": "node scripts/generate-asset-manifest.mjs",
    "assets:alias": "node scripts/fix-asset-aliases.mjs",
    "assets:classify": "node scripts/asset-pipeline/classify.mjs --out reports/asset-purpose.json",
    "assets:verify-scale": "node scripts/asset-pipeline/verify-scale.mjs --out reports/asset-scale.json",
    "assets:pipeline": "node scripts/asset-pipeline/pipeline.mjs",
    "assets:convert": "node scripts/asset-pipeline/convert.mjs",
    "assets:convert:doctor": "node scripts/asset-pipeline/convert.mjs doctor",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "smoke:prod:open": "node scripts/smoke-prod.mjs --base https://open.grudge-studio.com",
    "smoke:prod:portal": "node scripts/smoke-prod.mjs --base https://grudge-studio.com",
    "readiness:anims": "node scripts/readiness-anim-packs.mjs",
    "ci:test": "npm --prefix artifacts/animator run test -- src/three/retargetMap.test.ts src/lib/annihilateHero.test.ts",
    "deploy:prod": "node scripts/vercel-build.mjs && npx vercel deploy --prod --yes",
    "verify:assets": "node scripts/verify-fleet-assets.mjs",
    "verify:assets:cdn": "node scripts/verify-fleet-assets.mjs --cdn-only",
    "verify:assets:open": "node scripts/verify-fleet-assets.mjs --base https://open.grudge-studio.com",
    "content:index": "node scripts/content-index.mjs",
    "readiness:weapons": "node scripts/readiness-weapons.mjs",
    "scaffold:weapon": "node scripts/scaffold-weapon.mjs",
    "scenes:build": "node scripts/build-forge-scenes.mjs",
    "test:runtime": "npm --prefix lib/grudge-runtime test",
    "test:physics": "npm --prefix lib/grudge-physics test",
    "assets:outdoor:upload": "node scripts/upload-outdoor-r2.mjs",
    "assets:outdoor:upload:dry": "node scripts/upload-outdoor-r2.mjs --dry-run",
    "assets:outdoor:seed-d1": "node scripts/seed-outdoor-d1.mjs",
    "assets:outdoor:seed-d1:apply": "node scripts/seed-outdoor-d1.mjs --apply",
    "assets:outdoor:pipeline": "node scripts/upload-outdoor-r2.mjs && node scripts/seed-outdoor-d1.mjs --apply",
    "assets:outdoor:pipeline:dry": "node scripts/upload-outdoor-r2.mjs --dry-run && node scripts/seed-outdoor-d1.mjs --dry-run",
    "assets:packs:seed-d1": "node scripts/seed-packs-d1.mjs --apply",
    "assets:production:upload": "node scripts/upload-production-glbs-r2.mjs",
    "assets:production:seed-d1": "node scripts/seed-production-glbs-d1.mjs",
    "assets:production:seed-d1:apply": "node scripts/seed-production-glbs-d1.mjs --apply",
    "assets:production:pipeline": "node scripts/upload-production-glbs-r2.mjs && node scripts/seed-production-glbs-d1.mjs --apply",
    "assets:voxel-last30:stage": "node scripts/stage-voxel-last30.mjs",
    "assets:voxel-last30:seed-d1": "node scripts/seed-voxel-last30-d1.mjs",
    "assets:voxel-last30:seed-d1:apply": "node scripts/seed-voxel-last30-d1.mjs --apply",
    "assets:voxel-last30:upload": "node scripts/upload-local-glbs-wrangler.mjs models/voxel",
    "assets:voxel-last30:pipeline": "node scripts/stage-voxel-last30.mjs && node scripts/upload-local-glbs-wrangler.mjs models/voxel && node scripts/seed-voxel-last30-d1.mjs --apply",
    "assets:voxel-last30:deployments": "node scripts/update-voxel-deployments.mjs",
    "assets:voxel-last30:deployments:dry": "node scripts/update-voxel-deployments.mjs --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0"
  }
}
