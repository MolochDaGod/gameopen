    {
      "source": "/api/auth/popup-token",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/auth/popup-token"
    },
    {
      "source": "/api/auth/me",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/auth/me"
    },
    {
      "source": "/api/auth/verify",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/auth/verify"
    },
    { "source": "/api/auth/:path*", "destination": "https://id.grudge-studio.com/api/auth/:path*" },
    { "source": "/auth/:path*", "destination": "https://id.grudge-studio.com/auth/:path*" },
    { "source": "/login", "destination": "https://id.grudge-studio.com/login" },
