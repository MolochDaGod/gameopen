    },
    {
      "source": "/models/weapons/:path*",
      "destination": "https://assets.grudge-studio.com/models/weapons/:path*"
    },
    {
      "source": "/anim/:path*",
      "destination": "https://assets.grudge-studio.com/anim/:path*"
    },
    {
      "source": "/api/space",
      "destination": "https://voxgrudge-grudox-room-production.up.railway.app/api/space"
    },
    {
      "source": "/api/brawl",
      "destination": "https://voxgrudge-grudox-room-production.up.railway.app/api/brawl"
    },
    {
      "source": "/api/carrier",
      "destination": "https://voxgrudge-grudox-room-production.up.railway.app/api/carrier"
    },
    {
      "source": "/api/blocks",
      "destination": "https://mine-loader-api-production.up.railway.app/api/blocks"
    },
    {
      "source": "/api/blocks/:path*",
      "destination": "https://mine-loader-api-production.up.railway.app/api/blocks/:path*"
    },
    {
      "source": "/api/definitions",
      "destination": "https://mine-loader-api-production.up.railway.app/api/definitions"
    },
    {
      "source": "/api/definitions/:path*",
      "destination": "https://mine-loader-api-production.up.railway.app/api/definitions/:path*"
    },
    {
      "source": "/api/healthz",
      "destination": "https://mine-loader-api-production.up.railway.app/api/healthz"
    },
    {
      "source": "/api/worlds",
      "destination": "https://mine-loader-api-production.up.railway.app/api/worlds"
    },
    {
      "source": "/api/worlds/:path*",
      "destination": "https://mine-loader-api-production.up.railway.app/api/worlds/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://gameopen-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!assets/|models/|textures/|anim/|anims/|cdn/|icons/|ui/|rooms/|frames/|favicon|logo|opengraph|robots|asset-manifest|manifest|sw\\.js|pwa-|apple-touch|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; frame-ancestors 'self' https://id.grudge-studio.com https://open.grudge-studio.com https://*.grudge-studio.com https://puter.com https://*.puter.com https://*.puter.site; frame-src 'self' blob: data: https://*.grudge-studio.com https://*.vercel.app https://vercel.live https://*.vercel.live https://grudgewarlords.com https://*.grudgewarlords.com https://id.grudge-studio.com https://puter.com https://*.puter.com https://*.puter.site https://*.clerk.accounts.dev https://clerk.com https://*.clerk.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://*.grudge-studio.com https://*.vercel.app https://vercel.live https://*.clerk.accounts.dev https://clerk.com https://*.clerk.com https://js.puter.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com https://vercel.live https://*.vercel.live; img-src 'self' data: blob: https://assets.grudge-studio.com https://*.grudge-studio.com https://*.vercel.app https://img.clerk.com; media-src 'self' blob: data: https://assets.grudge-studio.com https://*.grudge-studio.com https://*.audius.co https://audius.co https://*.audiusgateway.com; worker-src 'self' blob:; child-src 'self' blob:; connect-src 'self' blob: data: https://*.grudge-studio.com https://*.vercel.app https://*.up.railway.app https://*.clerk.accounts.dev https://clerk.com https://*.clerk.com https://vercel.live wss://*.grudge-studio.com wss://*.up.railway.app wss://*.vercel.app https://js.puter.com https://api.puter.com https://fonts.googleapis.com https://fonts.gstatic.com https://static.cloudflareinsights.com https://cloudflareinsights.com https://api.audius.co https://*.audius.co https://audius.co https://*.audiusgateway.com; object-src 'none'; base-uri 'self'"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/models/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/textures/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/anim/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
