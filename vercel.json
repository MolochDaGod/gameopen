    {
      "source": "/api/professions",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/professions"
    },
    {
      "source": "/api/professions/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/professions/:path*"
    },
    {
      "source": "/api/island",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/island"
    },
    {
      "source": "/api/island/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/island/:path*"
    },
    {
      "source": "/api/wallet",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/wallet"
    },
    {
      "source": "/api/wallet/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/wallet/:path*"
    },
    {
      "source": "/api/nfts",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/nfts"
    },
    {
      "source": "/api/nfts/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/nfts/:path*"
    },
    {
      "source": "/api/objectstore/:path*",
      "destination": "https://info.grudge-studio.com/api/:path*"
    },
    {
      "source": "/api/ai/health",
      "destination": "https://ai.grudge-studio.com/health"
    },
    {
      "source": "/api/ai/v1/:path*",
      "destination": "https://ai.grudge-studio.com/v1/:path*"
    },
    {
      "source": "/api/ai/:path*",
      "destination": "https://ai.grudge-studio.com/:path*"
    },
    {
      "source": "/api/asset-registry",
      "destination": "https://api.grudge-studio.com/assets"
    },
    {
      "source": "/api/asset-registry/:path*",
      "destination": "https://api.grudge-studio.com/assets/:path*"
    },
    {
      "source": "/api/assets/:path*",
      "destination": "https://assets.grudge-studio.com/:path*"
    },
    {
      "source": "/anims/baked/:path*",
      "destination": "https://grudge-arena.grudge-studio.com/anims/baked/:path*"
    },
    {
      "source": "/cdn/assets/characters/:path*",
      "destination": "https://grudge-arena.grudge-studio.com/cdn/assets/characters/:path*"
    },
    {
      "source": "/textures/grudge6/:path*",
      "destination": "https://assets.grudge-studio.com/textures/grudge6/:path*"
    },
    {
      "source": "/models/grudge6/:path*",
      "destination": "https://assets.grudge-studio.com/models/grudge6/:path*"
    },
    {
      "source": "/models/voxels/:path*",
      "destination": "https://assets.grudge-studio.com/models/voxels/:path*"
    },
    {
      "source": "/assets/western-kingdoms/:path*",
      "destination": "https://assets.grudge-studio.com/assets/western-kingdoms/:path*"
    },
    {
      "source": "/assets/barbarians/:path*",
