{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/vercel-build.mjs",
  "installCommand": "echo skip-root-install",
  "outputDirectory": "artifacts/animator/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/auth/callback", "destination": "/index.html" },
    { "source": "/sign-in", "destination": "/index.html" },
    { "source": "/sign-in/:path*", "destination": "/index.html" },
    { "source": "/sign-up", "destination": "/index.html" },
    { "source": "/sign-up/:path*", "destination": "/index.html" },
    { "source": "/api/auth/:path*", "destination": "https://id.grudge-studio.com/api/auth/:path*" },
    { "source": "/auth/:path*", "destination": "https://id.grudge-studio.com/auth/:path*" },
    { "source": "/login", "destination": "https://id.grudge-studio.com/login" },
    {
      "source": "/api/health",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/health"
    },
    {
      "source": "/api/health/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/health/:path*"
    },
    {
      "source": "/api/characters",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/characters"
    },
    {
      "source": "/api/characters/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/characters/:path*"
    },
    {
      "source": "/api/account",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/account"
    },
    {
      "source": "/api/account/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/account/:path*"
    },
    {
      "source": "/api/inventory",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/inventory"
    },
    {
      "source": "/api/inventory/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/inventory/:path*"
    },
    {
      "source": "/api/professions",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/professions"
    },
    {
      "source": "/api/professions/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/professions/:path*"
    },
    {
      "source": "/api/island",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/island"
    },
    {
      "source": "/api/island/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/island/:path*"
    },
    {
      "source": "/api/wallet",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/wallet"
    },
    {
      "source": "/api/wallet/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/wallet/:path*"
    },
    {
      "source": "/api/nfts",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/nfts"
    },
    {
      "source": "/api/nfts/:path*",
      "destination": "https://grudge-api-production-0d46.up.railway.app/api/nfts/:path*"
    },
    {
      "source": "/api/objectstore/:path*",
      "destination": "https://objectstore.grudge-studio.com/api/:path*"
    },
    {
      "source": "/api/assets/:path*",
      "destination": "https://assets.grudge-studio.com/gameopen/:path*"
    },
    {
      "source": "/anims/baked/:path*",
      "destination": "https://grudge-arena.grudge-studio.com/anims/baked/:path*"
    },
    {
      "source": "/cdn/assets/characters/:path*",
      "destination": "https://grudge-arena.grudge-studio.com/cdn/assets/characters/:path*"
    },
    {
      "source": "/models/grudge/:path*",
      "destination": "https://threejs-rapier-react-three-controll.vercel.app/models/grudge/:path*"
    },
    {
      "source": "/models/weapons/:path*",
      "destination": "https://threejs-rapier-react-three-controll.vercel.app/models/weapons/:path*"
    },
    {
      "source": "/anim/:path*",
      "destination": "https://threejs-rapier-react-three-controll.vercel.app/anim/:path*"
    },
    {
      "source": "/api/space",
      "destination": "https://voxgrudge-grudox-room-production.up.railway.app/api/space"
    },
    {
      "source": "/api/brawl",
      "destination": "https://voxgrudge-grudox-room-production.up.railway.app/api/brawl"
    },
    {
      "source": "/api/carrier",
      "destination": "https://voxgrudge-grudox-room-production.up.railway.app/api/carrier"
    },
    {
      "source": "/api/blocks",
      "destination": "https://mine-loader.vercel.app/api/blocks"
    },
    {
      "source": "/api/:path*",
      "destination": "https://gameopen-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!assets/|models/|anim/|icons/|ui/|rooms/|frames/|favicon|logo|opengraph|robots|asset-manifest|manifest|sw\\.js|pwa-|apple-touch|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://id.grudge-studio.com https://open.grudge-studio.com https://*.grudge-studio.com https://puter.com https://*.puter.com https://*.puter.site"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/models/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/anim/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
