# ═══════════════════════════════════════════════════════════════════════════
# Grudge Open / gameopen — fleet environment
# Copy to .env.local (never commit secrets). Values mirrored from survival /
# GrudgeBuilder production where possible.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server (Railway) ──────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
ALLOWED_ORIGINS=https://gameopen.vercel.app,https://grudges.grudge-studio.com,https://survival.grudge-studio.com,https://open.grudge-studio.com,http://localhost:5173,http://localhost:3000

# Fleet identity + game data SSOT
GRUDGE_ID_URL=https://id.grudge-studio.com
GRUDGE_BUILDER_API=https://grudge-api-production-0d46.up.railway.app
# Shared JWT with GrudgeBuilder / survival so Bearer tokens validate
# JWT_SECRET=
# SESSION_SECRET=
# INTERNAL_API_KEY=
# ADMIN_TOKEN=

# Postgres (optional — survival Railway public URL for shared game DB reads)
# DATABASE_URL=
# DATABASE_PUBLIC_URL=

# Assets CDN / R2
ASSETS_CDN=https://assets.grudge-studio.com
OBJECTSTORE_URL=https://objectstore.grudge-studio.com/api/v1
OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com
OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_KEY=
# OBJECT_STORAGE_SECRET=
R2_BUCKET_ASSETS=grudge-assets
R2_BUCKET=grudge-assets
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
R2_PREFIX=gameopen

# Puter deployer (optional server-side KV)
# PUTER_AUTH_TOKEN=

# Optional Clerk (private roster / gallery)
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_PROXY_URL=

# ── Client (Vercel) ───────────────────────────────────────────────────────
# VITE_CLERK_PUBLISHABLE_KEY=
# VITE_CLERK_PROXY_URL=
VITE_GAME_SERVER_URL=wss://gameopen-production.up.railway.app
# GRUDOX shared game-zone room server (Ruins Brawler + other GRUDOX zones).
# Distinct from VITE_GAME_SERVER_URL: gameopen's Danger Room stays on its own
# api-server (GRUDOX has no /api/danger).
VITE_ZONE_SERVER_URL=wss://voxgrudge-grudox-room-production.up.railway.app
VITE_USE_R2=false
VITE_ASSET_BASE_URL=https://assets.grudge-studio.com/gameopen
VITE_GRUDGE_API_BASE=https://grudge-api-production-0d46.up.railway.app
VITE_ASSET_CDN_URL=https://assets.grudge-studio.com

# Animator Vite
BASE_PATH=/
PORT=5173
