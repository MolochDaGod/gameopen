# ═══════════════════════════════════════════════════════════════════════════
# Grudge Open / gameopen — fleet environment
# Copy to .env.local for local dev. Never commit actual secrets.
# See DEPLOY.md for Vercel + Railway production setup.
# ═══════════════════════════════════════════════════════════════════════════

# ── api-server (Railway gameopen-production) ────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# REQUIRED: comma-separated origins allowed to call this api-server
# Production set: gameopen.vercel.app, open.grudge-studio.com, localhost
ALLOWED_ORIGINS=https://gameopen.vercel.app,https://open.grudge-studio.com,https://grudges.grudge-studio.com,http://localhost:5173,http://localhost:3000

# Fleet identity
GRUDGE_ID_URL=https://id.grudge-studio.com
GRUDGE_BUILDER_API=https://grudge-api-production-0d46.up.railway.app

# REQUIRED on Railway (copy from GrudgeBuilder Railway → Settings → Variables)
# JWT_SECRET=<same as grudge-api-production JWT_SECRET>
# SESSION_SECRET=<random 64-char hex>
# INTERNAL_API_KEY=<shared with grudge-api-production>
# ADMIN_TOKEN=

# Optional Postgres (for direct DB reads — not needed if proxying to grudge-api)
# DATABASE_URL=postgresql://...
# DATABASE_PUBLIC_URL=postgresql://...

# Assets
ASSETS_CDN=https://assets.grudge-studio.com
OBJECTSTORE_URL=https://objectstore.grudge-studio.com/api/v1
OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com
OBJECT_STORAGE_REGION=auto
R2_BUCKET_ASSETS=grudge-assets
R2_BUCKET=grudge-assets
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
R2_PREFIX=gameopen

# Clerk (optional — only needed for gallery/private roster features)
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_PROXY_URL=

# Puter deployer (optional server-side KV)
# PUTER_AUTH_TOKEN=

# ── animator Vite (Vercel build env) ───────────────────────────────────────────────────────
# Set these in Vercel project → Settings → Environment Variables.

# REQUIRED for R2 CDN asset delivery (set to "true" in production)
VITE_USE_R2=false
# CDN base for models/icons/audio (must match R2 gameopen/ prefix)
VITE_ASSET_BASE_URL=https://assets.grudge-studio.com/gameopen
VITE_ASSET_CDN_URL=https://assets.grudge-studio.com

# Game server WebSocket endpoints
VITE_GAME_SERVER_URL=wss://gameopen-production.up.railway.app
# GRUDOX shared game-zone room server (Ruins Brawler + other GRUDOX zones).
# Distinct from VITE_GAME_SERVER_URL: gameopen's Danger Room stays on its own
# api-server (GRUDOX has no /api/danger).
VITE_ZONE_SERVER_URL=wss://voxgrudge-grudox-room-production.up.railway.app

# Railway game data API (for client-side direct fetch if not using Vercel proxy)
VITE_GRUDGE_API_BASE=https://grudge-api-production-0d46.up.railway.app

# ObjectStore definitions URL (for contentUrl() helper)
VITE_OBJECTSTORE_URL=https://objectstore.grudge-studio.com/api/v1

# Clerk (OPTIONAL — fleet auth is Grudge ID). Broken clerk.gameopen.vercel.app FAPI
# caused ERR_CONNECTION_CLOSED; leave disabled unless FAPI domain is healthy.
# VITE_CLERK_ENABLED=true
# VITE_CLERK_PUBLISHABLE_KEY=
# VITE_CLERK_PROXY_URL=

# Local dev
BASE_PATH=/
PORT=5173
