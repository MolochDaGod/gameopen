# ── Railway API ──────────────────────────────────────────────
PORT=8080
NODE_ENV=production
ALLOWED_ORIGINS=https://gameopen.vercel.app,https://grudges.grudge-studio.com,https://open.grudge-studio.com,http://localhost:5173,http://localhost:3000

# Fleet upstreams
GRUDGE_BUILDER_API=https://grudge-api-production-0d46.up.railway.app
GRUDGE_ID_URL=https://id.grudge-studio.com
ASSETS_CDN=https://assets.grudge-studio.com
OBJECTSTORE_URL=https://objectstore.grudge-studio.com/api/v1

# Optional Clerk (client build used VITE_CLERK_PUBLISHABLE_KEY)
# CLERK_SECRET_KEY=

# ── Cloudflare R2 (scripts/upload-r2.mjs) ────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=grudge-assets
# R2_PUBLIC_BASE=https://assets.grudge-studio.com
# R2_PREFIX=gameopen

# ── Vercel client (set in Vercel dashboard) ──────────────────
# VITE_ASSET_BASE_URL=https://assets.grudge-studio.com/gameopen
# VITE_API_BASE_URL=
# VITE_USE_R2=true
